<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="org.openmw.vr"
    android:installLocation="auto">

    <!-- Quest: 6DoF headset, GLES 3.x via gl4es. -->
    <uses-feature android:name="android.hardware.vr.headtracking" android:version="1" android:required="true" />
    <uses-feature android:glEsVersion="0x00030001" android:required="true" />
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />
    <!-- Declare hand-tracking support so the headset doesn't force the "controllers required"
         launch gate (controllers still work; this just lets it launch straight into VR). -->
    <uses-feature android:name="oculus.software.handtracking" android:required="false" />

    <!-- Read a shared /sdcard/Morrowind data folder (legacy storage; see targetSdk 29). -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- Android 11+ package visibility: let the statically-linked OpenXR loader reach the
         runtime/API-layer broker so it can find the headset's OpenXR runtime. -->
    <queries>
        <provider android:authorities="org.khronos.openxr.runtime_broker;org.khronos.openxr.system_runtime_broker" />
        <intent>
            <action android:name="org.khronos.openxr.OpenXRRuntimeService" />
        </intent>
        <intent>
            <action android:name="org.khronos.openxr.OpenXRApiLayerService" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:hasCode="true"
        android:label="OpenMW VR"
        android:requestLegacyExternalStorage="true">

        <!-- Standalone VR runtime mode (Quest/Pico). -->
        <meta-data android:name="com.samsung.android.vr.application.mode" android:value="vr_only" />
        <meta-data android:name="com.oculus.supportedDevices" android:value="quest2|questpro|quest3|quest3s" />
        <meta-data android:name="com.oculus.handtracking.frequency" android:value="HIGH" />
        <meta-data android:name="com.oculus.handtracking.version" android:value="V2.0" />

        <activity
            android:name="org.openmw.vr.OpenMWActivity"
            android:label="OpenMW VR"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
            android:configChanges="screenSize|screenLayout|orientation|keyboardHidden|keyboard|navigation|uiMode|density"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:resizeableActivity="false"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- Launches as an immersive VR app on the headset. -->
                <category android:name="com.oculus.intent.category.VR" />
            </intent-filter>
        </activity>
    </application>
</manifest>
